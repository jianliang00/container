<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.apple.container.cri-shim-macos</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/container-cri-shim-macos</string>
        <string>--config</string>
        <string>/etc/kubernetes/container-cri-shim-macos-config.json</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/container-cri-shim-macos.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/container-cri-shim-macos.log</string>
</dict>
</plist>
